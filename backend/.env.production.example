# EKIP Backend - Production Environment Variables
# Copy these to Render Dashboard > Environment Variables

# App Configuration
APP_NAME=EKIP
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS (comma-separated origins or * for all)
CORS_ORIGINS=https://your-frontend.onrender.com,https://yourdomain.com

# Database - Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Vector Database - Qdrant
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_DOCUMENTS=ekip_documents
QDRANT_COLLECTION_MEMORY=ekip_memory

# Graph Database - Neo4j Aura
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# LLM Providers
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

DEFAULT_LLM_PROVIDER=gemini

# Rate Limiting & Upload Settings
RATE_LIMIT_QUERIES_PER_MINUTE=30
RATE_LIMIT_UPLOADS_PER_HOUR=50
MAX_UPLOAD_SIZE_MB=50
